#: usr/lib/live-installer/installer.py:45
msgid ""
"ERROR: You must first manually mount your target filesystem(s) at /target to "
"do a custom install!"
msgstr ""
"ຂໍ້ຜິດພາດ: ເຈົ້າຕ້ອງ mount ລະບົບແຟ້ມເປົ້າໝາຍ ຢູ່ /target "
"ຈຶ່ງຈະສາມາດຕິດຕັ້ງດ້ວຍໂຕເອງໄດ້!"

#: usr/lib/live-installer/installer.py:106
#, python-format
msgid "Copying /%s"
msgstr "ກຳລັງສຳເນົາ /%s"

